---
import Layout from '~/layouts/MainLayout.astro';

import Hero from '~/components/Hero.astro';
import Services from '~/components/Services.astro';
import AppSection from '~/components/AppSection.astro';
import Contact from '~/components/Contact.astro';

const metadata = {
  title: 'TaxiTitan — Servicii de taxi rapide si sigure',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    title="TaxiTitan"
    subtitle="Servicii de taxi rapide si sigure."
    primaryAction={{ text: 'Contacteaza-ne', href: '#contact' }}
    secondaryAction={{ text: 'Servicii', href: '#services' }}
  />

  <Services
    title="Serviciile noastre"
    subtitle="Ce oferim clientilor nostri."
    items={[
      {
        title: 'Transport rapid',
        description: 'Ajungi unde ai nevoie, cand ai nevoie.',
      },
      {
        title: 'Preturi corecte',
        description: 'Tarife transparente, fara surprize.',
      },
      {
        title: 'Disponibilitate 24/7',
        description: 'Suntem disponibili non-stop pentru tine.',
      },
    ]}
  />

  <AppSection
    title="Descarca aplicatia"
    description="Comanda un taxi direct din telefon."
    googlePlayUrl="#"
    appStoreUrl="#"
  />

  <Contact
    title="Contacteaza-ne"
    subtitle="Ai o intrebare? Trimite-ne un mesaj."
  />
</Layout>
