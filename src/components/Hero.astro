---
export interface Props {
  title?: string;
  subtitle?: string;
  primaryAction?: { text: string; href: string };
  secondaryAction?: { text: string; href: string };
}

const { title, subtitle, primaryAction, secondaryAction } = Astro.props;
---

<section class="relative md:-mt-[76px] not-prose">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="pt-0 md:pt-[76px]"></div>
    <div class="py-12 md:py-20">
      <div class="text-center max-w-4xl mx-auto">
        {title && (
          <h1 class="text-5xl md:text-6xl font-bold leading-tighter tracking-tighter mb-4 font-heading dark:text-gray-200">
            <Fragment set:html={title} />
          </h1>
        )}
        {subtitle && (
          <p class="text-xl text-muted mb-8 dark:text-slate-300">
            <Fragment set:html={subtitle} />
          </p>
        )}
        {(primaryAction || secondaryAction) && (
          <div class="flex flex-col sm:flex-row sm:justify-center gap-4 max-w-xs sm:max-w-md mx-auto">
            {primaryAction && (
              <a href={primaryAction.href} class="btn-primary">{primaryAction.text}</a>
            )}
            {secondaryAction && (
              <a href={secondaryAction.href} class="btn">{secondaryAction.text}</a>
            )}
          </div>
        )}
      </div>
    </div>
  </div>
</section>
