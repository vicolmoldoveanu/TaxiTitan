---
export interface Props {
  title?: string;
  description?: string;
  googlePlayUrl?: string;
  appStoreUrl?: string;
}

const { title, description, googlePlayUrl, appStoreUrl } = Astro.props;
---

<section class="relative not-prose scroll-mt-[72px]" id="app">
  <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
  <div class="relative mx-auto max-w-7xl px-4 md:px-6 py-12 md:py-16 lg:py-20 text-default">
    <div class="text-center max-w-3xl mx-auto">
      {title && <h2 class="text-3xl md:text-4xl font-bold leading-tighter tracking-tighter font-heading text-heading mb-4" set:html={title} />}
      {description && <p class="text-xl text-muted mb-8" set:html={description} />}
      {(googlePlayUrl || appStoreUrl) && (
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          {googlePlayUrl && (
            <a href={googlePlayUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
              Google Play
            </a>
          )}
          {appStoreUrl && (
            <a href={appStoreUrl} target="_blank" rel="noopener noreferrer" class="btn">
              App Store
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>
